<div class="rughaus-pdp-benefits">
  <div class="rughaus-pdp-benefits__item">
    <div class="rughaus-pdp-benefits__icon-wrap">
      <svg
        class="rughaus-pdp-benefits__icon"
        viewBox="0 0 20 20"
        aria-hidden="true"
        focusable="false"
      >
        {% render 'icon', icon: 'chat_bubble' %}
      </svg>
    </div>
    <p class="rughaus-pdp-benefits__label">Worry-Free Support</p>
  </div>

  <div class="rughaus-pdp-benefits__item">
    <div class="rughaus-pdp-benefits__icon-wrap">
      <svg
        class="rughaus-pdp-benefits__icon"
        viewBox="0 0 20 20"
        aria-hidden="true"
        focusable="false"
      >
        {% render 'icon', icon: 'plane' %}
      </svg>
    </div>
    <p class="rughaus-pdp-benefits__label">Free Worldwide Shipping</p>
  </div>

  <div class="rughaus-pdp-benefits__item">
    <div class="rughaus-pdp-benefits__icon-wrap">
      <svg
        class="rughaus-pdp-benefits__icon"
        viewBox="0 0 20 20"
        aria-hidden="true"
        focusable="false"
      >
        {% render 'icon', icon: 'check_box' %}
      </svg>
    </div>
    <p class="rughaus-pdp-benefits__label">Exclusively Ours</p>
  </div>
</div>

{% stylesheet %}
  .rughaus-pdp-benefits {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    width: 100%;
    padding: 12px;
    background: #f5f2ed;
    border-radius: 2px;
  }

  .rughaus-pdp-benefits__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .rughaus-pdp-benefits__icon-wrap {
    width: 56px;
    height: 56px;
    display: grid;
    place-items: center;
    background: rgb(var(--color-background-rgb));
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 6px;
  }

  .rughaus-pdp-benefits__icon {
    width: 24px;
    height: 24px;
  }

  .rughaus-pdp-benefits__label {
    margin: 0;
    font-family: var(--font-paragraph--family);
    font-size: var(--font-paragraph--size);
    line-height: var(--font-paragraph--line-height);
    font-weight: var(--font-paragraph--weight);
    color: rgb(var(--color-foreground-rgb));
    text-wrap: balance;
  }

  @media screen and (max-width: 749px) {
    .rughaus-pdp-benefits {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 14px 12px;
    }
  }
{% endstylesheet %}
