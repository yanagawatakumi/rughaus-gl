<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--page-width color-{{ section.settings.color_scheme }} about-nk spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="about-nk__intro">
    {% if section.settings.eyebrow != blank %}
      <p class="about-nk__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="about-nk__title">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.lead != blank %}
      <div class="about-nk__lead rte">{{ section.settings.lead }}</div>
    {% endif %}
  </div>

  {% if section.settings.image_1 != blank or section.settings.image_2 != blank %}
    <div class="about-nk__images">
      {% if section.settings.image_1 != blank %}
        <div class="about-nk__image-wrap">
          {{
            section.settings.image_1
            | image_url: width: 1800
            | image_tag:
              loading: 'lazy',
              widths: '600, 900, 1200, 1600, 1800',
              sizes: '(min-width: 990px) 50vw, 100vw',
              class: 'about-nk__image'
          }}
        </div>
      {% endif %}

      {% if section.settings.image_2 != blank %}
        <div class="about-nk__image-wrap">
          {{
            section.settings.image_2
            | image_url: width: 1800
            | image_tag:
              loading: 'lazy',
              widths: '600, 900, 1200, 1600, 1800',
              sizes: '(min-width: 990px) 50vw, 100vw',
              class: 'about-nk__image'
          }}
        </div>
      {% endif %}
    </div>
  {% endif %}

  <div class="about-nk__details">
    <article class="about-nk__detail-card">
      {% if section.settings.code_title != blank %}
        <h2 class="about-nk__card-title">{{ section.settings.code_title }}</h2>
      {% endif %}
      {% if section.settings.code_text != blank %}
        <div class="about-nk__card-text rte">{{ section.settings.code_text }}</div>
      {% endif %}
    </article>

    <article class="about-nk__detail-card">
      {% if section.settings.cert_title != blank %}
        <h2 class="about-nk__card-title">{{ section.settings.cert_title }}</h2>
      {% endif %}
      {% if section.settings.cert_text != blank %}
        <div class="about-nk__card-text rte">{{ section.settings.cert_text }}</div>
      {% endif %}
    </article>
  </div>
</section>

{% stylesheet %}
  .about-nk {
    gap: clamp(2rem, 4vw, 4rem) 0;
  }

  .about-nk__intro {
    grid-column: 2;
    display: grid;
    gap: 1rem;
    max-width: 72rem;
  }

  .about-nk__eyebrow {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .about-nk__title {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .about-nk__lead {
    max-width: 52rem;
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.55;
  }

  .about-nk__images {
    grid-column: 1 / -1;
    display: grid;
    gap: var(--page-margin);
  }

  .about-nk__image-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .about-nk__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-nk__details {
    grid-column: 2;
    display: grid;
    gap: 1.5rem;
  }

  .about-nk__detail-card {
    padding-block: 1.25rem;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
  }

  .about-nk__card-title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.2rem, 2vw, 1.8rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .about-nk__card-text {
    max-width: 42rem;
  }

  @media screen and (min-width: 990px) {
    .about-nk__intro {
      grid-template-columns: minmax(0, 12rem) minmax(0, 1fr);
      align-items: start;
      column-gap: 2rem;
    }

    .about-nk__eyebrow {
      grid-column: 1;
      align-self: start;
      padding-top: 0.4rem;
    }

    .about-nk__title,
    .about-nk__lead {
      grid-column: 2;
    }

    .about-nk__images {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .about-nk__details {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NK About Page",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About Rughaus"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "From our home to yours"
    },
    {
      "type": "richtext",
      "id": "lead",
      "label": "Lead text",
      "default": "<p>Rughaus is built for design professionals seeking high-quality rugs with thoughtful materials, dependable support, and custom flexibility for real projects.</p>"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "inline_richtext",
      "id": "code_title",
      "label": "Code of conduct title",
      "default": "Code of conduct"
    },
    {
      "type": "richtext",
      "id": "code_text",
      "label": "Code of conduct text",
      "default": "<p>We partner with trusted workshops and prioritize transparent sourcing, respectful labor practices, and long-term product quality.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "cert_title",
      "label": "Certification title",
      "default": "GoodWeave certified"
    },
    {
      "type": "richtext",
      "id": "cert_text",
      "label": "Certification text",
      "default": "<p>Our partner network is selected to support responsible craftsmanship and traceable production standards.</p>"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "NK About Page"
    }
  ]
}
{% endschema %}
