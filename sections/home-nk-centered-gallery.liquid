{% liquid
  assign featured_collection = section.settings.featured_collection
  assign featured_product_blocks = section.blocks | where: 'type', 'featured_product'
  assign section_width_class = 'section--page-width'
  if section.settings.section_width == 'full-width'
    assign section_width_class = 'section--full-width'
  endif
%}

<section
  class="section {{ section_width_class }} nk-centered-gallery nk-centered-gallery--{{ section.settings.section_width }} spacing-style"
  style="
    {% render 'spacing-style', settings: section.settings %}
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  "
>
  <div class="nk-centered-gallery__inner">
    <div class="nk-centered-gallery__head">
      {% if section.settings.heading != blank %}
        <h2 class="nk-centered-gallery__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="nk-centered-gallery__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.link_label != blank and section.settings.link != blank %}
        <a class="nk-centered-gallery__cta" href="{{ section.settings.link }}">
          {{ section.settings.link_label }}
        </a>
      {% endif %}
    </div>

    {% capture featured_cards %}
      {% if section.settings.featured_source == 'manual' %}
        {% if featured_product_blocks.size > 0 %}
          {% for block in featured_product_blocks limit: section.settings.featured_limit %}
            {% liquid
              assign product = block.settings.product
              assign product_link = block.settings.link
              assign card_title = block.settings.title
              assign card_image = block.settings.image
              assign lead_time_text = blank
              assign price_per_m2_text = blank

              if product != blank
                if product_link == blank
                  assign product_link = product.url
                endif

                if card_title == blank
                  capture card_title_resolved
                    render 'rughaus-product-title', product: product
                  endcapture
                  assign card_title = card_title_resolved | strip
                endif

                if card_image == blank and product.featured_media != blank
                  assign card_image = product.featured_media
                endif

                assign lead_time_text = product.metafields.custom.pdp_delivery_shipping.value | strip

                capture card_price_per_area
                  render 'rug-price-per-area', product: product
                endcapture
                assign price_per_m2_text = card_price_per_area | strip
              endif
            %}
            <div class="nk-centered-gallery__slide" {{ block.shopify_attributes }}>
              <article class="nk-centered-gallery__card">
                <a class="nk-centered-gallery__product-link" href="{{ product_link | default: '#' }}">
                  <div class="nk-centered-gallery__product-media">
                    {% if card_image != blank %}
                      {{
                        card_image
                        | image_url: width: 1400
                        | image_tag:
                          loading: 'lazy',
                          widths: '400, 600, 900, 1200, 1400',
                          sizes: '(min-width: 1200px) 16vw, (min-width: 990px) 17vw, (min-width: 750px) 26vw, 56vw',
                          class: 'nk-centered-gallery__product-image'
                      }}
                    {% else %}
                      <img
                        src="{{ 'home-nk-category-all.jpg' | asset_url }}"
                        alt="Sample rug image"
                        class="nk-centered-gallery__product-image"
                        loading="lazy"
                        width="1080"
                        height="1350"
                      >
                    {% endif %}
                  </div>
                  <div class="nk-centered-gallery__meta">
                    <p class="nk-centered-gallery__product-title">{{ card_title | default: 'Sample Rug' }}</p>
                    {% unless block.settings.hide_price %}
                      {% if lead_time_text != blank %}
                        <p class="nk-centered-gallery__product-info">
                          {{ 'rughaus.centered_gallery.lead_time_label' | t }} {{ lead_time_text }}
                        </p>
                      {% endif %}
                      {% if price_per_m2_text != blank %}
                        <p class="nk-centered-gallery__product-info">
                          {{ 'rughaus.centered_gallery.price_label' | t }} {{ price_per_m2_text }}
                        </p>
                      {% endif %}
                    {% endunless %}
                  </div>
                </a>
              </article>
            </div>
          {% endfor %}
        {% endif %}
      {% elsif featured_collection != blank and featured_collection.products_count > 0 %}
        {% for product in featured_collection.products limit: section.settings.featured_limit %}
          {% liquid
            assign lead_time_text = product.metafields.custom.pdp_delivery_shipping.value | strip
            capture card_price_per_area
              render 'rug-price-per-area', product: product
            endcapture
            assign price_per_m2_text = card_price_per_area | strip
          %}
          <div class="nk-centered-gallery__slide">
            <article class="nk-centered-gallery__card">
              <a class="nk-centered-gallery__product-link" href="{{ product.url }}">
                <div class="nk-centered-gallery__product-media">
                  {% if product.featured_media != blank %}
                    {{
                      product.featured_media
                      | image_url: width: 1400
                      | image_tag:
                        loading: 'lazy',
                        widths: '400, 600, 900, 1200, 1400',
                        sizes: '(min-width: 1200px) 16vw, (min-width: 990px) 17vw, (min-width: 750px) 26vw, 56vw',
                        class: 'nk-centered-gallery__product-image'
                    }}
                  {% else %}
                    <img
                      src="{{ 'home-nk-category-all.jpg' | asset_url }}"
                      alt="Sample rug image"
                      class="nk-centered-gallery__product-image"
                      loading="lazy"
                      width="1080"
                      height="1350"
                    >
                  {% endif %}
                </div>
                <div class="nk-centered-gallery__meta">
                  <p class="nk-centered-gallery__product-title">{% render 'rughaus-product-title', product: product %}</p>
                  {% if lead_time_text != blank %}
                    <p class="nk-centered-gallery__product-info">
                      {{ 'rughaus.centered_gallery.lead_time_label' | t }} {{ lead_time_text }}
                    </p>
                  {% endif %}
                  {% if price_per_m2_text != blank %}
                    <p class="nk-centered-gallery__product-info">
                      {{ 'rughaus.centered_gallery.price_label' | t }} {{ price_per_m2_text }}
                    </p>
                  {% endif %}
                </div>
              </a>
            </article>
          </div>
        {% endfor %}
      {% endif %}
    {% endcapture %}

    {% if featured_cards != blank %}
      <div
        class="nk-centered-gallery__loop"
        data-home-nk-loop
        data-home-nk-visible-mobile="1.2"
        data-home-nk-visible-tablet="2.6"
        data-home-nk-visible-desktop="4.3"
        data-home-nk-autoplay="{{ section.settings.autoplay }}"
        data-home-nk-autoplay-speed="{{ section.settings.autoplay_speed }}"
      >
        <div class="nk-centered-gallery__track" data-home-nk-track>
          <div class="nk-centered-gallery__group" data-home-nk-group="prev" aria-hidden="true">{{ featured_cards }}</div>
          <div class="nk-centered-gallery__group" data-home-nk-group="main">{{ featured_cards }}</div>
          <div class="nk-centered-gallery__group" data-home-nk-group="next" aria-hidden="true">{{ featured_cards }}</div>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script src="{{ 'home-nk-trending-loop.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% stylesheet %}
  .nk-centered-gallery__inner {
    grid-column: 2;
    display: grid;
    gap: 1.25rem;
  }

  .nk-centered-gallery--full-width .nk-centered-gallery__inner {
    grid-column: var(--full-width);
  }

  .nk-centered-gallery__head {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 0.4rem;
  }

  .nk-centered-gallery__title {
    margin: 0;
    font-size: clamp(1.3rem, 2.6vw, 2.15rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .nk-centered-gallery__subtitle {
    margin: 0;
    font-size: 1rem;
    font-style: italic;
    opacity: 0.86;
  }

  .nk-centered-gallery__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.45rem;
    min-height: 2.3rem;
    padding: 0.4rem 1.75rem;
    background: #000;
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem;
    line-height: 1;
  }

  .nk-centered-gallery__loop {
    --slideshow-gap: 0.8rem;
    --home-nk-slide-width: 72vw;

    width: 100vw;
    margin-inline: calc(50% - 50vw);
    display: block;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    touch-action: pan-y;
  }

  .nk-centered-gallery__loop::-webkit-scrollbar {
    display: none;
  }

  .nk-centered-gallery__loop.is-dragging {
    cursor: grabbing;
  }

  .nk-centered-gallery__track {
    display: flex;
    min-width: max-content;
    gap: var(--slideshow-gap);
  }

  .nk-centered-gallery__group {
    display: flex;
    gap: var(--slideshow-gap);
    padding-block: 0.25rem;
    flex: 0 0 auto;
  }

  .nk-centered-gallery__slide {
    width: var(--home-nk-slide-width-px, var(--home-nk-slide-width));
    min-width: var(--home-nk-slide-width-px, var(--home-nk-slide-width));
    max-width: var(--home-nk-slide-width-px, var(--home-nk-slide-width));
    flex: 0 0 var(--home-nk-slide-width-px, var(--home-nk-slide-width));
  }

  .nk-centered-gallery__card,
  .nk-centered-gallery__product-link {
    display: block;
    width: 100%;
    min-width: 0;
    text-decoration: none;
    color: inherit;
  }

  .nk-centered-gallery__product-link {
    position: relative;
  }

  .nk-centered-gallery__product-media {
    position: relative;
    aspect-ratio: 4 / 5;
    width: 100%;
    background: rgb(var(--color-foreground-rgb) / 0.06);
    overflow: hidden;
  }

  .nk-centered-gallery__product-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nk-centered-gallery__meta {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 1;
    display: grid;
    gap: 0.2rem;
    padding: 0.65rem 0.8rem;
    background: rgb(255 255 255 / 0.86);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.22s ease, transform 0.22s ease;
    pointer-events: none;
  }

  .nk-centered-gallery__product-title,
  .nk-centered-gallery__product-info {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.25;
    overflow-wrap: anywhere;
  }

  .nk-centered-gallery__product-info {
    opacity: 0.82;
  }

  @media screen and (min-width: 750px) {
    .nk-centered-gallery__loop {
      --slideshow-gap: 1rem;
      --home-nk-slide-width: 34vw;
    }
  }

  @media screen and (min-width: 990px) {
    .nk-centered-gallery__loop {
      --home-nk-slide-width: 21.5vw;
    }
  }

  @media screen and (min-width: 990px) and (hover: hover) and (pointer: fine) {
    .nk-centered-gallery__product-link:hover .nk-centered-gallery__meta,
    .nk-centered-gallery__product-link:focus-visible .nk-centered-gallery__meta {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NK Centered Gallery",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "featured_product",
      "name": "Featured product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title override"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link override"
        },
        {
          "type": "checkbox",
          "id": "hide_price",
          "label": "Hide product info",
          "default": false
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable auto slide",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Auto slide speed",
      "min": 20,
      "max": 180,
      "step": 5,
      "unit": "px",
      "default": 85
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Custom Rugs, made easy"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Measure to order in your favorite pattern and color"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Button label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f2f0ec"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1f1f1f"
    },
    {
      "type": "select",
      "id": "featured_source",
      "label": "Featured source",
      "options": [
        {
          "value": "collection",
          "label": "Collection (auto)"
        },
        {
          "value": "manual",
          "label": "Manual blocks"
        }
      ],
      "default": "collection"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured collection"
    },
    {
      "type": "range",
      "id": "featured_limit",
      "label": "Products to show",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 20
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "NK Centered Gallery",
      "blocks": [
        {
          "type": "featured_product"
        },
        {
          "type": "featured_product"
        },
        {
          "type": "featured_product"
        },
        {
          "type": "featured_product"
        }
      ]
    }
  ]
}
{% endschema %}
