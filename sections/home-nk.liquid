          "label": "Heading",
          "default": "Collection"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Short collection summary.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "support_link",
      "name": "Support link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Support topic"
        },
        {
          "type": "text",
          "id": "description",
