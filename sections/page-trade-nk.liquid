{% liquid
  assign benefit_blocks = section.blocks | where: 'type', 'benefit'
  assign project_blocks = section.blocks | where: 'type', 'project'
  assign quote_blocks = section.blocks | where: 'type', 'quote'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--page-width color-{{ section.settings.color_scheme }} trade-nk spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <header class="trade-nk__hero">
    {% if section.settings.eyebrow != blank %}
      <p class="trade-nk__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="trade-nk__title">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.lead != blank %}
      <div class="trade-nk__lead rte">{{ section.settings.lead }}</div>
    {% endif %}

    <div class="trade-nk__hero-actions">
      {% if section.settings.apply_label != blank and section.settings.apply_link != blank %}
        <a
          class="button"
          href="{{ section.settings.apply_link }}"
        >
          {{ section.settings.apply_label }}
        </a>
      {% endif %}

      {% if section.settings.contact_label != blank and section.settings.contact_link != blank %}
        <a
          class="button button-secondary"
          href="{{ section.settings.contact_link }}"
        >
          {{ section.settings.contact_label }}
        </a>
      {% endif %}
    </div>
  </header>

  {% if benefit_blocks.size > 0 %}
    <div class="trade-nk__benefits">
      {% for block in benefit_blocks %}
        <article
          class="trade-nk__benefit"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.heading != blank %}
            <h2 class="trade-nk__benefit-title">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="trade-nk__benefit-text rte">{{ block.settings.text }}</div>
          {% endif %}
          {% if block.settings.link_label != blank and block.settings.link != blank %}
            <a
              class="trade-nk__benefit-link"
              href="{{ block.settings.link }}"
            >
              {{ block.settings.link_label }}
            </a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}

  {% if project_blocks.size > 0 %}
    <div class="trade-nk__projects">
      {% for block in project_blocks %}
        <figure
          class="trade-nk__project"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1800
              | image_tag:
                loading: 'lazy',
                widths: '600, 900, 1200, 1600, 1800',
                sizes: '(min-width: 990px) 33vw, 100vw',
                class: 'trade-nk__project-image'
            }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'trade-nk__project-image trade-nk__project-image--placeholder' }}
          {% endif %}

          {% if block.settings.caption != blank %}
            <figcaption class="trade-nk__project-caption">{{ block.settings.caption }}</figcaption>
          {% endif %}
        </figure>
      {% endfor %}
    </div>
  {% endif %}

  {% if quote_blocks.size > 0 %}
    <div class="trade-nk__quotes">
      {% for block in quote_blocks %}
        <blockquote
          class="trade-nk__quote"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.quote != blank %}
            <div class="trade-nk__quote-text rte">{{ block.settings.quote }}</div>
          {% endif %}
          {% if block.settings.author != blank %}
            <cite class="trade-nk__quote-author">{{ block.settings.author }}</cite>
          {% endif %}
        </blockquote>
      {% endfor %}
    </div>
  {% endif %}

  <div class="trade-nk__footer">
    {% if section.settings.footer_heading != blank %}
      <h2 class="trade-nk__footer-title">{{ section.settings.footer_heading }}</h2>
    {% endif %}
    {% if section.settings.footer_text != blank %}
      <div class="trade-nk__footer-text rte">{{ section.settings.footer_text }}</div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .trade-nk {
    gap: clamp(2rem, 4vw, 4rem) 0;
  }

  .trade-nk__hero,
  .trade-nk__footer {
    grid-column: 2;
    max-width: 64rem;
    display: grid;
    gap: 1rem;
  }

  .trade-nk__eyebrow {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .trade-nk__title {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .trade-nk__lead {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.55;
  }

  .trade-nk__hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .trade-nk__benefits {
    grid-column: 2;
    display: grid;
    gap: 1rem;
  }

  .trade-nk__benefit {
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    padding-top: 1rem;
    display: grid;
    gap: 0.75rem;
  }

  .trade-nk__benefit-title {
    margin: 0;
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .trade-nk__benefit-link {
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .trade-nk__projects {
    grid-column: 1 / -1;
    display: grid;
    gap: var(--page-margin);
  }

  .trade-nk__project {
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .trade-nk__project-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    background: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .trade-nk__project-image--placeholder {
    padding: 2rem;
  }

  .trade-nk__project-caption {
    font-size: 0.8rem;
    line-height: 1.4;
    opacity: 0.75;
  }

  .trade-nk__quotes {
    grid-column: 2;
    display: grid;
    gap: 1rem;
  }

  .trade-nk__quote {
    margin: 0;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    padding-top: 1rem;
    display: grid;
    gap: 0.75rem;
  }

  .trade-nk__quote-text {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
  }

  .trade-nk__quote-author {
    font-style: normal;
    opacity: 0.75;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .trade-nk__footer-title {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 2rem);
    text-transform: uppercase;
  }

  @media screen and (min-width: 990px) {
    .trade-nk__benefits {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
    }

    .trade-nk__projects {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .trade-nk__quotes {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
    }
  }
{% endstylesheet %}

