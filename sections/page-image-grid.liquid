{% liquid
  assign image_blocks = section.blocks | where: 'type', 'image'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} page-image-grid spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <div class="page-image-grid__head">
      <h2 class="page-image-grid__heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if image_blocks.size > 0 %}
    <div class="page-image-grid__list page-image-grid__list--{{ section.settings.columns_desktop }}">
      {% for block in image_blocks %}
        {% liquid
          assign has_link = false
          if block.settings.link != blank
            assign has_link = true
          endif
        %}
        <figure class="page-image-grid__item" {{ block.shopify_attributes }}>
          {% if has_link %}<a class="page-image-grid__image-link" href="{{ block.settings.link }}">{% endif %}
          <div class="page-image-grid__media page-image-grid__media--{{ section.settings.aspect_ratio }}">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 2000
                | image_tag:
                  loading: 'lazy',
                  widths: '600, 900, 1200, 1600, 2000',
                  sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                  class: 'page-image-grid__image'
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'page-image-grid__image page-image-grid__image--placeholder' }}
            {% endif %}
          </div>
          {% if has_link %}</a>{% endif %}

          {% if block.settings.caption != blank %}
            <figcaption class="page-image-grid__caption">{{ block.settings.caption }}</figcaption>
          {% endif %}
        </figure>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .page-image-grid__head {
    grid-column: 2;
    margin-bottom: 1rem;
  }

  .page-image-grid__heading {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 2rem);
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .page-image-grid__list {
    grid-column: 1 / -1;
    display: grid;
    gap: var(--page-margin);
  }

  .page-image-grid__item {
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  .page-image-grid__media {
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .page-image-grid__media--portrait {
    aspect-ratio: 4 / 5;
  }

  .page-image-grid__media--square {
    aspect-ratio: 1;
  }

  .page-image-grid__media--landscape {
    aspect-ratio: 16 / 9;
  }

  .page-image-grid__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .page-image-grid__image--placeholder {
    padding: 2rem;
  }

  .page-image-grid__caption {
    font-size: 0.85rem;
    opacity: 0.78;
  }

  @media screen and (min-width: 750px) {
    .page-image-grid__list--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .page-image-grid__list--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .page-image-grid__list--4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Page Image Grid",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "full-width"
    },
    { "type": "inline_richtext", "id": "heading", "label": "Heading" },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "portrait", "label": "4:5" },
        { "value": "square", "label": "1:1" },
        { "value": "landscape", "label": "16:9" }
      ],
      "default": "portrait"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Page Image Grid" }]
}
{% endschema %}
