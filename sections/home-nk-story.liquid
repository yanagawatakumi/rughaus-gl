<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--page-width color-{{ section.settings.color_scheme }} home-nk-story-section spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="home-nk__story" aria-label="Brand story">
    <div class="home-nk__story-media">
      {% if section.settings.story_image != blank %}
        {{
          section.settings.story_image
          | image_url: width: 1800
          | image_tag:
            loading: 'lazy',
            widths: '700, 1000, 1300, 1600, 1800',
            sizes: '(min-width: 990px) 44vw, 100vw',
            class: 'home-nk__story-image'
        }}
      {% else %}
        <img
          src="{{ 'home-nk-story.jpg' | asset_url }}"
          alt="Rughaus story image"
          class="home-nk__story-image"
          loading="lazy"
          width="1200"
          height="1200"
        >
      {% endif %}
    </div>

    <div class="home-nk__story-content">
      {% if section.settings.story_eyebrow != blank %}
        <p class="home-nk__eyebrow">{{ section.settings.story_eyebrow }}</p>
      {% endif %}

      {% if section.settings.story_heading != blank %}
        <h2 class="home-nk__section-title">{{ section.settings.story_heading }}</h2>
      {% endif %}

      {% if section.settings.story_text != blank %}
        <div class="home-nk__story-text rte">{{ section.settings.story_text }}</div>
      {% endif %}

      {% if section.settings.story_link_label != blank and section.settings.story_link != blank %}
        <a class="button button-secondary" href="{{ section.settings.story_link }}">{{ section.settings.story_link_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .home-nk-story-section {
    display: grid;
  }

  .home-nk__story {
    grid-column: 2;
    display: grid;
    gap: 1rem;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    padding-top: clamp(1.5rem, 3vw, 2rem);
  }

  .home-nk__story-media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .home-nk__story-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-nk__story-content {
    display: grid;
    gap: 0.9rem;
    align-content: start;
    min-width: 0;
  }

  .home-nk__eyebrow {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .home-nk__section-title {
    margin: 0;
    font-size: clamp(1.45rem, 3vw, 2.5rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    overflow-wrap: anywhere;
  }

  .home-nk__story-text {
    max-width: 54ch;
    overflow-wrap: anywhere;
  }

  @media screen and (min-width: 990px) {
    .home-nk__story {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
      gap: 1.5rem;
    }

    .home-nk__story-media {
      aspect-ratio: 5 / 4;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NK Story",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "story_eyebrow",
      "label": "Story eyebrow",
      "default": "About"
    },
    {
      "type": "inline_richtext",
      "id": "story_heading",
      "label": "Story heading",
      "default": "Crafted for spaces that evolve"
    },
    {
      "type": "richtext",
      "id": "story_text",
      "label": "Story text",
      "default": "<p>Our rug program combines custom sizing, practical lead times, and material options selected for design-led projects.</p>"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story image"
    },
    {
      "type": "text",
      "id": "story_link_label",
      "label": "Story button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "story_link",
      "label": "Story button link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "NK Story"
    }
  ]
}
{% endschema %}
