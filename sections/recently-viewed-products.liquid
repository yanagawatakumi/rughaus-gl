<script
  src="{{ 'recently-viewed-section.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% liquid
  assign heading_text = section.settings.heading
  if heading_text == blank
    assign heading_text = 'content.recently_viewed_products' | t
  endif
%}

<recently-viewed-products-section
  data-section-id="{{ section.id }}"
  data-current-handle="{{ product.handle }}"
  data-currency="{{ cart.currency.iso_code }}"
  data-max-products="{{ section.settings.max_products }}"
  hidden
  {{ section.shopify_attributes }}
>
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <section
    class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} section-resource-list recently-viewed-products spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="section-resource-list__content">
      <h2 class="recently-viewed-products__title {{ section.settings.heading_size }}">
        {{ heading_text }}
      </h2>
    </div>

    <ul
      class="recently-viewed-products__grid list-unstyled"
      style="--recently-viewed-columns: {{ section.settings.columns }}; --recently-viewed-columns-mobile: {{ section.settings.mobile_columns }};"
      ref="recentlyViewedGrid"
    ></ul>
  </section>
</recently-viewed-products-section>

{% stylesheet %}
  recently-viewed-products-section {
    display: block;
    width: 100%;
  }

  .recently-viewed-products {
    row-gap: var(--gap-xl);
  }

  .recently-viewed-products .section-resource-list__content {
    align-items: flex-start;
  }

  .recently-viewed-products__title {
    margin: 0;
  }

  .recently-viewed-products__grid {
    display: grid;
    grid-template-columns: repeat(var(--recently-viewed-columns-mobile), minmax(0, 1fr));
    gap: var(--gap-lg);
    margin: 0;
    padding: 0;
  }

  .recently-viewed-products__item {
    min-width: 0;
  }

  .recently-viewed-products__card-link {
    color: inherit;
    text-decoration: none;
    display: grid;
    gap: var(--gap-xs);
  }

  .recently-viewed-products__image-wrap {
    background: rgb(var(--color-foreground-rgb) / 0.03);
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .recently-viewed-products__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .recently-viewed-products__name {
    margin: 0;
    line-height: 1.3;
  }

  .recently-viewed-products__price {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.8);
  }

  @media screen and (min-width: 750px) {
    .recently-viewed-products__grid {
      grid-template-columns: repeat(var(--recently-viewed-columns), minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Recently viewed products",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h3"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Recently viewed products"
    }
  ]
}
{% endschema %}
