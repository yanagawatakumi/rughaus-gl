
<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) {
          card.scrollIntoView({ behavior: 'instant' });
        }
      },
      { once: true }
    );
  }

  document.addEventListener('DOMContentLoaded', () => {
    const variantCards = document.querySelectorAll('.product-grid__item[data-variant-id][data-variant-url]');

    variantCards.forEach((card) => {
      const variantUrl = card.dataset.variantUrl;
      const variantImageUrl = card.dataset.variantImageUrl;

      if (variantUrl) {
        card.querySelectorAll('a[href*="/products/"]').forEach((link) => {
          link.setAttribute('href', variantUrl);
        });
      }

      if (variantImageUrl) {
        card.querySelectorAll('img').forEach((img) => {
          img.setAttribute('src', variantImageUrl);
          img.removeAttribute('srcset');
          img.removeAttribute('data-srcset');
          img.removeAttribute('data-sizes');
        });
      }
    });
  });
{% endjavascript %}

{% comment %} We always render this full-width, as the child blocks have width: page/full settings {% endcomment %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<results-list
  class="section product-grid-container color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div
    class="collection-wrapper grid gap-style{% if section.settings.product_grid_width == 'full-width' %} collection-wrapper--grid-full-width{% endif %}"
  >
    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}

    {% assign products_per_page = 24 %}

    {% if section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {% paginate collection.products by products_per_page %}
      {% capture children %}
        {% liquid
          assign variant_expansion_enabled = section.settings.enable_variant_expansion
          if template.name == 'collection' and template.suffix == 'custom-rugs'
            assign variant_expansion_enabled = true
          endif

          assign hide_collection_swatches = false
          if variant_expansion_enabled and section.settings.hide_color_swatches
            assign hide_collection_swatches = true
          endif
        %}
        {% for product in collection.products %}
          {% liquid
            assign featured_variants = blank
            if variant_expansion_enabled and product.metafields.custom.collection_featured_variants != blank
              capture featured_variants_raw
                echo product.metafields.custom.collection_featured_variants
              endcapture
              assign featured_variants_raw = featured_variants_raw | strip
              if featured_variants_raw contains 'gid://shopify/ProductVariant/'
                assign featured_variants_raw = featured_variants_raw | remove: '[' | remove: ']' | remove: '"' | remove: '&quot;' | remove: '&#34;'
                assign featured_variants = featured_variants_raw | split: ','
              else
                assign featured_variants = product.metafields.custom.collection_featured_variants.value
                if featured_variants == blank
                  assign featured_variants = product.metafields.custom.collection_featured_variants.references
                endif
              endif
            endif
          %}

          {% if variant_expansion_enabled and featured_variants != blank and featured_variants.size > 0 %}
            {% assign rendered_variant_cards = false %}
            {% for featured_variant_entry in featured_variants %}
              {% liquid
                assign featured_variant = blank

                if featured_variant_entry.id != blank
                  assign featured_variant = featured_variant_entry
                else
                  assign featured_variant_gid = featured_variant_entry | strip
                  if featured_variant_gid contains 'gid://shopify/ProductVariant/'
                    assign featured_variant_id = featured_variant_gid | split: '/' | last | plus: 0
                    assign featured_variant = product.variants | where: 'id', featured_variant_id | first
                  endif
                endif
              %}
              {% if featured_variant != blank %}
                {% assign rendered_variant_cards = true %}
                {% assign rughaus_card_variant = featured_variant %}
                <li
                  id="{{ section.id }}-{{ product.id }}-{{ featured_variant.id }}"
                  class="product-grid__item product-grid__item--{{ forloop.index0 }}"
                  data-page="{{ paginate.current_page }}"
                  data-product-id="{{ product.id }}"
                  data-variant-id="{{ featured_variant.id }}"
                  data-variant-url="{{ product.url }}?variant={{ featured_variant.id }}"
                  data-variant-image-url="{{ featured_variant.featured_media | default: product.featured_media | image_url: width: 1100 }}"
                  ref="cards[]"
                >
                  {% # theme-check-disable %}
                  {% content_for 'block',
                    type: '_product-card',
                    id: 'product-card',
                    closest.product: product
                  %}
                  {% # theme-check-enable %}
                </li>
                {% assign rughaus_card_variant = blank %}
              {% endif %}
            {% endfor %}
            {% unless rendered_variant_cards %}
              {% assign rughaus_card_variant = blank %}
              <li
                id="{{ section.id }}-{{ product.id }}"
                class="product-grid__item product-grid__item--{{ forloop.index0 }}"
                data-page="{{ paginate.current_page }}"
                data-product-id="{{ product.id }}"
                ref="cards[]"
              >
                {% # theme-check-disable %}
                {% content_for 'block',
                  type: '_product-card',
                  id: 'product-card',
                  closest.product: product
                %}
                {% # theme-check-enable %}
              </li>
            {% endunless %}
          {% else %}
            {% assign rughaus_card_variant = blank %}
            <li
              id="{{ section.id }}-{{ product.id }}"
              class="product-grid__item product-grid__item--{{ forloop.index0 }}"
              data-page="{{ paginate.current_page }}"
              data-product-id="{{ product.id }}"
              ref="cards[]"
            >
              {% # theme-check-disable %}
              {% content_for 'block',
                type: '_product-card',
                id: 'product-card',
                closest.product: product
              %}
              {% # theme-check-enable %}
            </li>
          {% endif %}
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: collection.products,
        paginate: paginate,
        enable_infinite_scroll: section.settings.enable_infinite_scroll
      %}
    {% endpaginate %}
  </div>
</results-list>

{% stylesheet %}
  .product-grid-container .quick-add,
  .product-grid-container .quick-add__button {
    display: none !important;
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.collection_container",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "organic",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "t:settings.card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "extra-large",
          "label": "t:options.extra_large"
        }
      ],
      "default": "medium",
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "t:settings.mobile_card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "large",
          "label": "t:options.large"
        }
      ],
      "default": "small"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "label": "t:settings.auto_load_products",
      "default": true
    },
    {
      "type": "header",
      "content": "Variant expansion"
    },
    {
      "type": "checkbox",
      "id": "enable_variant_expansion",
      "label": "Enable variant expansion cards",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_color_swatches",
      "label": "Hide color swatches when variant expansion is enabled",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:settings.products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 24,
      "visible_if": "{{ section.settings.enable_infinite_scroll == false }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "t:settings.full_width_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.product_grid_width != 'full-width' }}"
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": []
}
{% endschema %}
