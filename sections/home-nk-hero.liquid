<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--page-width color-{{ section.settings.color_scheme }} home-nk-hero-section spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <header class="home-nk__hero">
    <div class="home-nk__hero-content">
      {% if section.settings.hero_eyebrow != blank %}
        <p class="home-nk__eyebrow">{{ section.settings.hero_eyebrow }}</p>
      {% endif %}

      {% if section.settings.hero_heading != blank %}
        <h1 class="home-nk__heading">{{ section.settings.hero_heading }}</h1>
      {% endif %}

      {% if section.settings.hero_lead != blank %}
        <div class="home-nk__lead rte">{{ section.settings.hero_lead }}</div>
      {% endif %}

      <div class="home-nk__hero-actions">
        {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
          <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        {% endif %}

        {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
          <a class="button button-secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>
    </div>

    <div class="home-nk__hero-media home-nk__hero-media--primary">
      {% if section.settings.hero_video != blank %}
        {{
          section.settings.hero_video
          | video_tag:
            poster: nil,
            autoplay: true,
            loop: true,
            controls: false,
            muted: true,
            class: 'home-nk__hero-video'
        }}
      {% elsif section.settings.hero_image != blank %}
        {{
          section.settings.hero_image
          | image_url: width: 2600
          | image_tag:
            loading: 'eager',
            widths: '800, 1200, 1600, 2000, 2400, 2600',
            sizes: '(min-width: 990px) 58vw, 100vw',
            class: 'home-nk__hero-image'
        }}
      {% else %}
        <img
          src="{{ 'home-nk-hero-primary.jpg' | asset_url }}"
          alt="Rughaus hero image"
          class="home-nk__hero-image"
          loading="eager"
          width="1512"
          height="1008"
        >
      {% endif %}
    </div>
  </header>
</section>

{% stylesheet %}
  .home-nk-hero-section {
    display: grid;
  }

  .home-nk__hero {
    grid-column: 2;
    display: grid;
    gap: clamp(1.5rem, 2.5vw, 2rem);
  }

  .home-nk__hero-content {
    order: 2;
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .home-nk__eyebrow {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .home-nk__heading {
    margin: 0;
    font-size: clamp(2rem, 5vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    max-width: 16ch;
    overflow-wrap: normal;
    word-break: normal;
  }

  .home-nk__lead {
    max-width: 56ch;
    font-size: clamp(1rem, 1.7vw, 1.25rem);
    line-height: 1.55;
  }

  .home-nk__hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .home-nk__hero-media {
    order: 1;
    min-height: 20rem;
    background: rgb(var(--color-foreground-rgb) / 0.06);
    overflow: hidden;
  }

  .home-nk__hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-nk__hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (min-width: 990px) {
    .home-nk__hero {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      align-items: end;
      gap: 1.5rem;
    }

    .home-nk__hero-content,
    .home-nk__hero-media {
      order: initial;
    }

    .home-nk__hero-media--primary {
      min-height: 40rem;
      height: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NK Hero",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Eyebrow",
      "default": "RUGHAUS GL"
    },
    {
      "type": "inline_richtext",
      "id": "hero_heading",
      "label": "Heading",
      "default": "Architectural rugs for custom interiors"
    },
    {
      "type": "richtext",
      "id": "hero_lead",
      "label": "Lead text",
      "default": "<p>Build your specification in stock or custom dimensions, with concise support for trade projects.</p>"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Primary hero image"
    },
    {
      "type": "video",
      "id": "hero_video",
      "label": "Primary hero video",
      "info": "If set, video is shown instead of primary image."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop all rugs"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Custom rugs"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "NK Hero"
    }
  ]
}
{% endschema %}
