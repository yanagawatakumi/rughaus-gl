{% liquid
  assign card_blocks = section.blocks | where: 'type', 'card'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} page-card-grid spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <div class="page-card-grid__head">
      <h2 class="page-card-grid__heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if card_blocks.size > 0 %}
    <div class="page-card-grid__list page-card-grid__list--{{ section.settings.columns_desktop }}">
      {% for block in card_blocks %}
        <article class="page-card-grid__item page-card-grid__item--{{ section.settings.card_style }}" {{ block.shopify_attributes }}>
          {% if block.settings.heading != blank %}
            <h3 class="page-card-grid__title">{{ block.settings.heading }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="page-card-grid__text rte">{{ block.settings.text }}</div>
          {% endif %}

          {% if block.settings.link_label != blank and block.settings.link != blank %}
            <a class="page-card-grid__link text-link" href="{{ block.settings.link }}">{{ block.settings.link_label }}</a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .page-card-grid__head {
    grid-column: 2;
    margin-bottom: 1rem;
  }

  .page-card-grid__heading {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 2rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .page-card-grid__list {
    grid-column: 2;
    display: grid;
    gap: 1.25rem;
  }

  .page-card-grid__item {
    padding-top: 1rem;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    display: grid;
    gap: 0.75rem;
  }

  .page-card-grid__item--quote .page-card-grid__text {
    font-size: clamp(1rem, 1.35vw, 1.15rem);
  }

  .page-card-grid__title {
    margin: 0;
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .page-card-grid__link {
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media screen and (min-width: 990px) {
    .page-card-grid__list--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .page-card-grid__list--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Page Card Grid",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "inline_richtext", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "text", "id": "link_label", "label": "Link label" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    { "type": "inline_richtext", "id": "heading", "label": "Heading" },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "quote", "label": "Quote" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Page Card Grid" }]
}
{% endschema %}
