{% liquid
  assign featured_collection = section.settings.featured_collection
  assign featured_product_blocks = section.blocks | where: 'type', 'featured_product'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--page-width color-{{ section.settings.color_scheme }} home-nk-trending-section spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="home-nk__featured" aria-label="Trending rugs">
    <div class="home-nk__section-head">
      {% if section.settings.featured_heading != blank %}
        <h2 class="home-nk__section-title">{{ section.settings.featured_heading }}</h2>
      {% endif %}

      {% if section.settings.featured_link_label != blank and section.settings.featured_link != blank %}
        <a class="home-nk__text-link" href="{{ section.settings.featured_link }}">{{ section.settings.featured_link_label }}</a>
      {% endif %}
    </div>

    {% capture featured_cards %}
      {% if section.settings.featured_source == 'manual' %}
        {% if featured_product_blocks.size > 0 %}
          {% for block in featured_product_blocks limit: section.settings.featured_limit %}
            {% liquid
              assign product = block.settings.product
              assign product_link = block.settings.link
              assign card_title = block.settings.title
              assign card_image = block.settings.image

              if product != blank
                if product_link == blank
                  assign product_link = product.url
                endif

                if card_title == blank
                  assign card_title = product.title
                endif

                if card_image == blank and product.featured_media != blank
                  assign card_image = product.featured_media
                endif
              endif
            %}
            <div class="home-nk__product-slide">
              <article class="home-nk__product-card">
                <a class="home-nk__product-link" href="{{ product_link | default: '#' }}">
                  <div class="home-nk__product-media">
                    {% if card_image != blank %}
                      {{
                        card_image
                        | image_url: width: 1400
                        | image_tag:
                          loading: 'lazy',
                          widths: '400, 600, 900, 1200, 1400',
                          sizes: '(min-width: 1200px) 16vw, (min-width: 990px) 18vw, (min-width: 750px) 28vw, 62vw',
                          class: 'home-nk__product-image'
                      }}
                    {% else %}
                      <img
                        src="{{ 'home-nk-category-all.jpg' | asset_url }}"
                        alt="Sample rug image"
                        class="home-nk__product-image"
                        loading="lazy"
                        width="1080"
                        height="1080"
                      >
                    {% endif %}
                  </div>

                  <h3 class="home-nk__product-title">{{ card_title | default: 'Sample Rug' }}</h3>
                  {% unless block.settings.hide_price %}
                    <p class="home-nk__product-price">
                      {% if product != blank %}
                        {{ product.price | money }}
                      {% else %}
                        {{ 25000 | money }}
                      {% endif %}
                    </p>
                  {% endunless %}
                </a>
              </article>
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..4) limit: section.settings.featured_limit %}
            <div class="home-nk__product-slide">
              <article class="home-nk__product-card home-nk__product-card--placeholder">
                <div class="home-nk__product-media">
                  <img
                    src="{{ 'home-nk-category-all.jpg' | asset_url }}"
                    alt="Sample rug image {{ i }}"
                    class="home-nk__product-image"
                    loading="lazy"
                    width="1080"
                    height="1080"
                  >
                </div>
                <h3 class="home-nk__product-title">Sample Rug {{ i }}</h3>
                <p class="home-nk__product-price">{{ 25000 | money }}</p>
              </article>
            </div>
          {% endfor %}
        {% endif %}
      {% elsif featured_collection != blank and featured_collection.products_count > 0 %}
        {% for product in featured_collection.products limit: section.settings.featured_limit %}
          <div class="home-nk__product-slide">
            <article class="home-nk__product-card">
              <a class="home-nk__product-link" href="{{ product.url }}">
                <div class="home-nk__product-media">
                  {% if product.featured_media != blank %}
                    {{
                      product.featured_media
                      | image_url: width: 1400
                      | image_tag:
                        loading: 'lazy',
                        widths: '400, 600, 900, 1200, 1400',
                        sizes: '(min-width: 1200px) 16vw, (min-width: 990px) 18vw, (min-width: 750px) 28vw, 62vw',
                        class: 'home-nk__product-image'
                    }}
                  {% else %}
                    <img
                      src="{{ 'home-nk-category-all.jpg' | asset_url }}"
                      alt="Sample rug image"
                      class="home-nk__product-image"
                      loading="lazy"
                      width="1080"
                      height="1080"
                    >
                  {% endif %}
                </div>

                <h3 class="home-nk__product-title">{{ product.title }}</h3>
                <p class="home-nk__product-price">{{ product.price | money }}</p>
              </a>
            </article>
            </div>
        {% endfor %}
      {% else %}
        {% for i in (1..4) limit: section.settings.featured_limit %}
          <div class="home-nk__product-slide">
            <article class="home-nk__product-card home-nk__product-card--placeholder">
              <div class="home-nk__product-media">
                <img
                  src="{{ 'home-nk-category-all.jpg' | asset_url }}"
                  alt="Sample rug image {{ i }}"
                  class="home-nk__product-image"
                  loading="lazy"
                  width="1080"
                  height="1080"
                >
              </div>
              <h3 class="home-nk__product-title">Sample Rug {{ i }}</h3>
              <p class="home-nk__product-price">{{ 25000 | money }}</p>
            </article>
            </div>
        {% endfor %}
      {% endif %}
    {% endcapture %}

    <div class="home-nk__product-loop" data-home-nk-loop>
      <div class="home-nk__product-track" data-home-nk-track>
        <div class="home-nk__product-group" data-home-nk-group="prev" aria-hidden="true">{{ featured_cards }}</div>
        <div class="home-nk__product-group" data-home-nk-group="main">{{ featured_cards }}</div>
        <div class="home-nk__product-group" data-home-nk-group="next" aria-hidden="true">{{ featured_cards }}</div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'home-nk-trending-loop.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% stylesheet %}
  .home-nk-trending-section {
    display: grid;
  }

  .home-nk__featured {
    grid-column: 2;
    display: grid;
    gap: 1rem;
  }

  .home-nk__section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .home-nk__section-title {
    margin: 0;
    font-size: clamp(1.45rem, 3vw, 2.5rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    overflow-wrap: anywhere;
  }

  .home-nk__text-link {
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .home-nk__product-loop {
    --slideshow-gap: 0.75rem;
    --home-nk-slide-width: 62vw;

    width: 100%;
    display: block;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    touch-action: pan-y;
  }

  .home-nk__product-loop::-webkit-scrollbar {
    display: none;
  }

  .home-nk__product-loop.is-dragging {
    cursor: grabbing;
  }

  .home-nk__product-track {
    display: flex;
    min-width: max-content;
    gap: var(--slideshow-gap);
  }

  .home-nk__product-group {
    display: flex;
    gap: var(--slideshow-gap);
    padding-block: 0.25rem;
    flex: 0 0 auto;
  }

  .home-nk__product-slide {
    width: var(--home-nk-slide-width-px, var(--home-nk-slide-width));
    min-width: var(--home-nk-slide-width-px, var(--home-nk-slide-width));
    max-width: var(--home-nk-slide-width-px, var(--home-nk-slide-width));
    flex: 0 0 var(--home-nk-slide-width-px, var(--home-nk-slide-width));
  }

  .home-nk__product-card {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
    width: 100%;
  }

  .home-nk__product-link {
    display: grid;
    gap: 0.45rem;
    color: inherit;
    text-decoration: none;
    min-width: 0;
    width: 100%;
  }

  .home-nk__product-media {
    aspect-ratio: 4 / 5;
    width: 100%;
    background: rgb(var(--color-foreground-rgb) / 0.05);
    overflow: hidden;
  }

  .home-nk__product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-nk__product-title {
    margin: 0;
    font-size: 0.98rem;
    overflow-wrap: anywhere;
  }

  .home-nk__product-price {
    margin: 0;
    font-size: 0.95rem;
    opacity: 0.84;
  }

  @media screen and (min-width: 750px) {
    .home-nk__product-loop {
      --slideshow-gap: 0.9rem;
      --home-nk-slide-width: 28vw;
    }
  }

  @media screen and (min-width: 990px) {
    .home-nk__product-loop {
      --slideshow-gap: 1rem;
      --home-nk-slide-width: 17.5vw;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NK Trending Rugs",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "featured_product",
      "name": "Featured product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title override"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link override"
        },
        {
          "type": "checkbox",
          "id": "hide_price",
          "label": "Hide price",
          "default": false
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "featured_source",
      "label": "Featured source",
      "options": [
        {
          "value": "collection",
          "label": "Collection (auto)"
        },
        {
          "value": "manual",
          "label": "Manual blocks"
        }
      ],
      "default": "collection"
    },
    {
      "type": "inline_richtext",
      "id": "featured_heading",
      "label": "Featured heading",
      "default": "TRENDING RUGS"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured collection"
    },
    {
      "type": "range",
      "id": "featured_limit",
      "label": "Products to show",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 20
    },
    {
      "type": "text",
      "id": "featured_link_label",
      "label": "Featured link label",
      "default": "SHOP NOW ->"
    },
    {
      "type": "url",
      "id": "featured_link",
      "label": "Featured link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "NK Trending Rugs",
      "blocks": [
        {
          "type": "featured_product"
        },
        {
          "type": "featured_product"
        },
        {
          "type": "featured_product"
        },
        {
          "type": "featured_product"
        }
      ]
    }
  ]
}
{% endschema %}
