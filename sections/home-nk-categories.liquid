{% liquid
  assign category_blocks = section.blocks | where: 'type', 'category_card'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--page-width color-{{ section.settings.color_scheme }} home-nk-categories-section spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if category_blocks.size > 0 %}
    <div class="home-nk__categories" aria-label="Primary categories">
      {% for block in category_blocks %}
        <article class="home-nk__category" {{ block.shopify_attributes }}>
          <a class="home-nk__category-link" href="{{ block.settings.link | default: '#' }}">
            <div class="home-nk__category-media">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 1400
                  | image_tag:
                    loading: 'lazy',
                    widths: '400, 600, 900, 1200, 1400',
                    sizes: '(min-width: 990px) 27vw, (min-width: 750px) 32vw, 100vw',
                    class: 'home-nk__category-image'
                }}
              {% else %}
                {% liquid
                  assign category_fallback_asset = 'home-nk-category-all.jpg'
                  if block.settings.link contains 'custom-rugs'
                    assign category_fallback_asset = 'home-nk-category-custom.jpg'
                  elsif block.settings.link contains 'stock-rugs'
                    assign category_fallback_asset = 'home-nk-category-stock.jpg'
                  endif
                %}
                <img
                  src="{{ category_fallback_asset | asset_url }}"
                  alt="Rug category image"
                  class="home-nk__category-image"
                  loading="lazy"
                  width="1080"
                  height="1080"
                >
              {% endif %}
            </div>

            <div class="home-nk__category-body">
              {% if block.settings.heading != blank %}
                <h2 class="home-nk__category-title">{{ block.settings.heading }}</h2>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="home-nk__category-text rte">{{ block.settings.text }}</div>
              {% endif %}

              {% if block.settings.link_label != blank %}
                <span class="home-nk__category-cta">{{ block.settings.link_label }}</span>
              {% endif %}
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .home-nk-categories-section {
    display: grid;
  }

  .home-nk__categories {
    grid-column: 2;
    display: grid;
    gap: 0.75rem;
  }

  .home-nk__category {
    margin: 0;
    min-width: 0;
  }

  .home-nk__category-link {
    display: grid;
    gap: 1rem;
    color: inherit;
    text-decoration: none;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.18);
    padding: 0.6rem;
    transition: border-color 180ms ease;
    min-width: 0;
  }

  .home-nk__category-link:hover {
    border-color: rgb(var(--color-foreground-rgb) / 0.5);
  }

  .home-nk__category-media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .home-nk__category-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-nk__category-body {
    display: grid;
    gap: 0.5rem;
    align-content: start;
    min-width: 0;
  }

  .home-nk__category-title {
    margin: 0;
    font-size: clamp(1.1rem, 2.1vw, 1.6rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    overflow-wrap: anywhere;
  }

  .home-nk__category-text {
    font-size: 0.95rem;
    line-height: 1.55;
    opacity: 0.86;
    overflow-wrap: anywhere;
  }

  .home-nk__category-cta {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media screen and (min-width: 750px) {
    .home-nk__categories {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NK Categories",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "category_card",
      "name": "Category card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Collection"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Short collection summary.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "NK Categories",
      "blocks": [
        {
          "type": "category_card"
        },
        {
          "type": "category_card"
        },
        {
          "type": "category_card"
        }
      ]
    }
  ]
}
{% endschema %}
